# Copy to .env (gitignored) and fill in.
# Vercel: set with `vercel env add VAR_NAME` for each.

# --- Required: Supabase global leaderboard ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Optional: AI-generated power-ups (set ONE; tried in order, free first) ---
# FREE: OpenRouter (many :free model variants) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# FREE: Groq (Llama 3.3 70B, ~30 req/min) — https://console.groq.com
GROQ_API_KEY=
# FREE: Google Gemini Flash (1500 req/day) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# PAID: Anthropic Claude Haiku (~$0.0008/wish) — https://console.anthropic.com
ANTHROPIC_API_KEY=
